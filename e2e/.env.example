# E2E Test Environment Variables
# Copy to .env and fill in values

# Base URL of the deployed Luxlog app
E2E_BASE_URL=https://luxlog.vercel.app

# Test account credentials (create a dedicated test user on Supabase)
E2E_TEST_EMAIL=e2e-test@luxlog.app
E2E_TEST_PASSWORD=

# Optional: paths to test fixtures
E2E_TEST_IMAGE=./fixtures/test-photo.jpg
